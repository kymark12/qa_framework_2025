# Environment
ENVIRONMENT=local

# API Configuration
API_BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=10
API_RETRIES=3
API_RETRY_BACKOFF=0.5

# UI Configuration
UI_BASE_URL=https://www.saucedemo.com
UI_BROWSER=firefox
UI_HEADLESS=true
UI_SLOW_MOTION=0
UI_TIMEOUT=30000
UI_VIEWPORT_WIDTH=1280
UI_VIEWPORT_HEIGHT=720

# Logging
LOG_LEVEL=INFO
LOG_FORMAT='%(asctime)s - %(name)s - %(levelname)s - %(message)s'

# Feature Flags
RECORD_VIDEO=false
RECORD_TRACE=false